{
  "permissions": {
    "deny": [
      "Bash(*gh pr merge*)",
      "Bash(*git push --force *)",
      "Bash(*git push -f *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-tool-guard.sh"
          }
        ]
      }
    ]
  }
}
